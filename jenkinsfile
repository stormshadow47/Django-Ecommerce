pipeline {
    agent any
    environment {
        VENV = 'venv'
        DB_HOST = 'localhost'
        DB_NAME = 'ecom'
        DB_USER = 'root'
        DB_PASSWORD = 'root'
    }
    stages {
        stage('Git Checkout') {
            steps {
                git branch: 'master', url: 'https://github.com/stormshadow47/Django-Ecommerce.git'
            }
        }

        stage('Set up VENV') {
            steps {
                sh 'python -m venv venv'
                sh 'source venv/bin/activate'
                sh 'python -m pip install --upgrade pip'
                sh 'python -m pip install -r requirements.txt'
            }
        }

        stage('Run smoke tests') {
            steps {
                sh 'source venv/bin/activate'
                sh 'python manage.py test smoke_tests'
            }
        }

        stage('Run unit tests') {
            steps {
                sh 'source venv/bin/activate'
                sh 'python manage.py test Users.unit_tests Products.unit_tests cart.unit_tests orders.unit_tests'
            }
        }

        stage('Run integration tests') {
            steps {
                sh 'source venv/bin/activate'
                sh 'python manage.py test Users.tests Products.tests cart.tests orders.tests'
            }
        }

        stage('Run all tests') {
            steps {
                sh 'source venv/bin/activate'
                sh 'python manage.py test'
            }
        }
    }

    post {
        always {
            echo 'Test pipeline completed'
        }
        success {
            echo 'All tests passed successfully!'
        }
        failure {
            echo 'Tests failed. Please check the logs.'
        }
    }
}