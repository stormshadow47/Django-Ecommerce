pipeline {
    agent any
    environment {
        PATH = "${HOME}/.local/bin:${env.PATH}"
        DB_HOST = 'localhost'
        DB_NAME = 'ecom'
        DB_USER = 'root'
        DB_PASSWORD = 'root'
    }
    stages {
        stage('Git Checkout') {
            steps {
                git branch: 'master', url: 'https://github.com/stormshadow47/Django-Ecommerce.git'
            }
        }

        stage('Install System Dependencies') {
            steps {
                sh 'sudo apt-get update'
                sh 'sudo apt-get install -y default-libmysqlclient-dev pkg-config gcc g++ make'
            }
        }

        stage('Install pip') {
            steps {
                sh 'curl https://bootstrap.pypa.io/get-pip.py -o get-pip.py'
                sh 'python3 get-pip.py --break-system-packages'
            }
        }

        stage('Set up Dependencies') {
            steps {
                sh 'pip install --upgrade pip --break-system-packages'
                sh 'pip install -r requirements.txt --break-system-packages'
            }
        }

        stage('Run smoke tests') {
            steps {
                sh 'python3 manage.py test smoke_tests'
            }
        }

        stage('Run unit tests') {
            steps {
                sh 'python3 manage.py test Users.unit_tests Products.unit_tests cart.unit_tests orders.unit_tests'
            }
        }

        stage('Run integration tests') {
            steps {
                sh 'python3 manage.py test Users.tests Products.tests cart.tests orders.tests'
            }
        }

        stage('Run all tests') {
            steps {
                sh 'python3 manage.py test'
            }
        }
    }

    post {
        always {
            echo 'Test pipeline completed'
        }
        success {
            echo 'All tests passed successfully!'
        }
        failure {
            echo 'Tests failed. Please check the logs.'
        }
    }
}